[
  {
    "type": "project",
    "plugins": {
      "default": "../homebrew-plugin/src/index.ts"
    }
  },
  {
    "type": "nvm",
    "global": "18.20",
    "nodeVersions": [
      "18.20"
    ]
  },
  {
    "type": "homebrew",
    "formulae": [
      "cirruslabs/cli/cirrus",
      "cirruslabs/cli/tart"
    ]
  },
  {
    "type": "vscode"
  },

  { "type": "git-clone", "parentDirectory": "~/temp", "remote": "git@github.com:ComfortCooker/app.git" },
  { "type": "git-clone", "parentDirectory": "~/temp", "remote": "git@github.com:ComfortCooker/infrastructure.git" },
  { "type": "git-clone", "parentDirectory": "~/temp", "remote": "git@github.com:ComfortCooker/accounts.git" },

  { "type":  "path", "path":  "~/temp/infrastructure/bin", "dependsOn":  ["git-clone.1"] }
